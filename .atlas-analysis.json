  "keyFeatures": [
    "Lightweight state management for vanilla JS and React",
    "Immutable internal state with deep equality checks",
    "Selective subscriptions to minimize re-renders",
    "Support for internal actions via get/set initializer",
    "Persist middleware with localStorage, sessionStorage, and custom storage",
    "Auto-revalidate on window focus with configurable timeout",
    "Optional state encryption via btoa/atob",
    "Silent states in React for non-reactive state reads",
    "TypeScript-first with full type definitions"
  ],
  "publicApiSurface": [
    "createStore(initializer, options)",
    "store.getState()",
    "store.setState(fn, force?)",
    "store.subscribe(subscriber, selector?)",
    "store.resetState(state?)",
    "store.destroy()",
    "store.getServerState()",
    "useStore(store, selector, silect?)",
    "persist(config)",
    "normalizeStorage(initializerStorage, options?)",
    "Store<T>",
    "Options<T>",
    "Selector<T, U>",
    "Subscriber<T, U>",
    "PersistConfig<T>",
    "CustomStorage<T>",
    "StoreWithPersist"
  ]
